<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Announcement Tree View -->
    <record id="view_portal_announcement_tree" model="ir.ui.view">
        <field name="name">portal.announcement.tree</field>
        <field name="model">portal.announcement</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_published" decoration-info="is_published">
                <field name="name"/>
                <field name="date_published"/>
                <field name="date_expiry"/>
                <field name="all_employees"/>
                <field name="employee_ids" widget="many2many_tags" optional="show"/>
                <field name="is_published" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Announcement Form View -->
    <record id="view_portal_announcement_form" model="ir.ui.view">
        <field name="name">portal.announcement.form</field>
        <field name="model">portal.announcement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'zoom': true}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Annual Company Picnic"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_published"/>
                            <field name="date_expiry"/>
                        </group>
                        <group>
                            <field name="all_employees"/>
                            <field name="employee_ids" widget="many2many_tags" options="{'no_create': True}" invisible="all_employees"/>
                            <field name="is_published" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <group string="Short Summary (shown on listing cards)">
                                <field name="summary" nolabel="1" placeholder="Enter a brief summary..."/>
                            </group>
                            <group string="Full Notice Body">
                                <field name="content" nolabel="1" placeholder="Enter rich text notice content here..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter for backend discussion and portal feedback -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Announcement Search View -->
    <record id="view_portal_announcement_search" model="ir.ui.view">
        <field name="name">portal.announcement.search</field>
        <field name="model">portal.announcement</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="summary"/>
                <filter string="Published" name="published" domain="[('is_published', '=', True)]"/>
                <filter string="Draft" name="draft" domain="[('is_published', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Publish Date" name="group_by_publish" context="{'group_by':'date_published:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_portal_announcement" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">portal.announcement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_portal_announcement_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first company announcement!
            </p>
            <p>
                Announcements will be displayed on the Employee Portal Notice Board.
            </p>
        </field>
    </record>

    <!-- Menu Item under Employees -->
    <menuitem id="menu_portal_announcement"
              name="Announcements"
              parent="hr.menu_hr_root"
              action="action_portal_announcement"
              sequence="95"/>
</odoo>
